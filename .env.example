# =====================================================
# Sistema RH COPIA GROUP - Variaveis de Ambiente
# =====================================================

# Servidor
PORT=3000
NODE_ENV=development

# Autenticacao - GERAR NOVO SECRET EM PRODUCAO:
#   openssl rand -hex 64
JWT_SECRET=copia_group_super_secret_key_2025_change_in_production
JWT_EXPIRATION=8h

# =====================================================
# BASE DE DADOS - 4 modos suportados (prioridade)
# =====================================================
#
#   1. Supabase SDK         -> SUPABASE_URL + SUPABASE_SECRET_KEY definidos (recomendado)
#   2. Postgres direto      -> DATABASE_URL (precisa IPv4 pooler)
#   3. Turso (libsql)       -> TURSO_DATABASE_URL definido
#   4. Memory (prototipo)   -> MEMORY_MODE=1 ou Vercel sem outros
#   5. SQLite local         -> default em desenvolvimento
#
# === Modo Supabase SDK (recomendado para Vercel) ===
# Funciona via HTTPS/SDK (sem precisar de IPv4 pooler).
# Requer aplicar primeiro backend/data/supabase-rpc.sql no SQL Editor.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   (opcional - cliente browser)
#
# === Modo Postgres direto (avancado) ===
# Project Settings > Database > Connection string > Transaction pooler
# DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# === Modo Turso (libsql) ===
# TURSO_DATABASE_URL=libsql://rh-xxxx.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
#
# === Modo Memory ===
# MEMORY_MODE=1
