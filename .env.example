# =====================================================
# Sistema RH COPIA GROUP - Variaveis de Ambiente
# =====================================================

# Servidor
PORT=3000
NODE_ENV=development

# Autenticacao - GERAR NOVO SECRET EM PRODUCAO:
#   openssl rand -hex 64
JWT_SECRET=copia_group_super_secret_key_2025_change_in_production
JWT_EXPIRATION=8h

# =====================================================
# BASE DE DADOS - 3 modos suportados
# =====================================================
#
# Prioridade:
#   1. Turso  (TURSO_DATABASE_URL definido)
#   2. Memory (MEMORY_MODE=1, ou Vercel sem Turso - automatico)
#   3. SQLite local (backend/db/hr.db) - default em desenvolvimento
#
# --- Modo Turso (persistente, recomendado em producao) ---
# TURSO_DATABASE_URL=libsql://rh-copia-xxxxx.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
#
# --- Modo Memory (prototipo / demo) ---
# Carrega 162 colaboradores anonimizados de backend/data/employees-seed.json
# Escritas sao volateis (perdidas em cada cold start). Ideal para Vercel
# sem custo de BD externa.
# MEMORY_MODE=1
