# =====================================================
# Sistema RH COPIA GROUP - Variaveis de Ambiente
# =====================================================

# Servidor
PORT=3000
NODE_ENV=development

# Autenticacao - GERAR NOVO SECRET EM PRODUCAO:
#   openssl rand -hex 64
JWT_SECRET=copia_group_super_secret_key_2025_change_in_production
JWT_EXPIRATION=8h

# =====================================================
# BASE DE DADOS - Opcional: Turso (libsql)
# =====================================================
# Se TURSO_DATABASE_URL estiver definido, usa Turso.
# Caso contrario, usa SQLite local (backend/db/hr.db).
#
# Setup Turso (gratis):
#   1. https://turso.tech -> criar conta
#   2. turso db create rh-copia
#   3. turso db show rh-copia --url
#   4. turso db tokens create rh-copia
#
# Em produc\xE3o (Vercel), definir como Environment Variables.
# TURSO_DATABASE_URL=libsql://rh-copia-xxxxx.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
