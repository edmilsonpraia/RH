{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/css/(.*)", "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/frontend/js/$1" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1" },
    { "src": "/admin-dashboard.html", "dest": "/frontend/admin-dashboard.html" },
    { "src": "/user-dashboard.html", "dest": "/frontend/user-dashboard.html" },
    { "src": "/test-login.html", "dest": "/frontend/test-login.html" },
    { "src": "/test.html", "dest": "/frontend/test.html" },
    { "src": "/index.html", "dest": "/frontend/index.html" },
    { "src": "^/$", "dest": "/frontend/index.html" }
  ]
}
